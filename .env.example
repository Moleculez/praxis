# Database
DATABASE_URL=postgresql+asyncpg://praxis:praxis@localhost:5432/praxis
TIMESCALE_URL=postgresql+asyncpg://praxis:praxis@localhost:5433/praxis_ts

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO (S3-compatible)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=praxis-artifacts

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# LLM Gateway (OpenRouter recommended)
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
XAI_API_KEY=

# Local LLM (Ollama — for dev without API keys)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
USE_LOCAL_LLM=false

# Paper Trading
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
