# Database — SQLite by default (zero setup), Postgres for production
DATABASE_URL=sqlite+aiosqlite:///data/praxis.db
# DATABASE_URL=postgresql+asyncpg://praxis:praxis@localhost:5432/praxis
# TIMESCALE_URL=postgresql+asyncpg://praxis:praxis@localhost:5433/praxis_ts

# Redis — optional, leave empty to disable background workers
# REDIS_URL=redis://localhost:6379/0

# MinIO — optional, leave empty to use local filesystem (data/artifacts/)
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=praxis-artifacts

# MLflow — optional, leave empty to disable experiment tracking
# MLFLOW_TRACKING_URI=http://localhost:5000

# LLM Gateway (OpenRouter recommended — one key, all providers)
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=
# XAI_API_KEY=

# Local LLM (Ollama — for dev without API keys)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
USE_LOCAL_LLM=false

# Paper Trading
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Interactive Brokers (Client Portal Gateway)
IBKR_ACCOUNT_ID=
IBKR_GATEWAY_URL=https://localhost:5000

# Broker selection: alpaca | ibkr
BROKER=alpaca
