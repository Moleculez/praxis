{
  "name": "praxis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "turbo format",
    "dev:infra": "docker compose up -d",
    "dev:infra:down": "docker compose down",
    "migrate": "alembic upgrade head",
    "test:py": "cd services/backend && python -m pytest -q",
    "lint:py": "ruff check services/",
    "typecheck:py": "mypy --strict services/",
    "format:py": "ruff format services/"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
